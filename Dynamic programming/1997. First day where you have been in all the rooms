class Solution {
public:
    int firstDayBeenInAllRooms(vector<int>& nums) {
        int n=nums.size();
        int MOD=1e9 + 7;
        vector<long long>dp(n,0);
        for(int i=0;i<n-1;i++){
            dp[i+1]=(dp[i]+1+(dp[i]-dp[nums[i]])+1+MOD)%MOD;
        }
        return dp[n-1]; 
    }
};
