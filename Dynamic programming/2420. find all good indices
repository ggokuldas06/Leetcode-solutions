class Solution {
public:
    vector<int> goodIndices(vector<int>& nums, int k) {
        int n = nums.size();
        vector<int> dpb(n, 0); 
        vector<int> dpf(n, 0); 
        for(int i = 1; i < n; i++){
            if(nums[i] <= nums[i-1])
                dpb[i] = dpb[i-1] + 1;
        }
        for(int i = n-2; i >= 0; i--){
            if(nums[i] <= nums[i+1])
                dpf[i] = dpf[i+1] + 1;
        }
        vector<int> ans;
        for(int i = k; i < n - k; i++){
            if(dpb[i-1] >= k-1 && dpf[i+1] >= k-1){
                ans.push_back(i);
            }
        }
        return ans;
    }
};
