class Solution {
public:
    int longestSubarray(vector<int>& nums) { 
        int n=nums.size();
        vector<int> l(n, 1), r(n, 1); 
        for(int i=1;i<n;i++){
            if(nums[i]>=nums[i-1]){
                l[i]+=l[i-1];
            }
        }
        for(int i=n-2;i>=0;i--){
            if(nums[i]<=nums[i+1]){
                r[i]+=r[i+1];
            }
        }
        int ans=1;
        if(n==1)return 1;
        for(int i=0;i<n;i++){
            ans=max(ans,l[i]);
            if(i==0){
                ans=max(ans,1+r[i+1]);
            }
            else if(i==n-1){
                ans=max(ans,1+l[i-1]);
            }
            else{
                if(nums[i-1] <= nums[i+1]){
                    ans=max(ans,1+l[i-1]+r[i+1]);
                }
                else{
                    ans=max(ans,1+max(l[i-1],r[i+1]));
                }

            }
        }
        return ans;
    }
};
