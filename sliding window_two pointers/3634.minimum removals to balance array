class Solution {
public:
    int minRemoval(vector<int>& nums, int k) {
        sort(nums.begin(),nums.end());
        int left=0;
        int ans=1;
        for(int right=1;right<nums.size();right++){
            while((long long)nums[left]*k < nums[right] && left<=right){
                left++;
            }
            ans=max(ans,right-left+1);
        }
        return nums.size()-ans;
    }
};
