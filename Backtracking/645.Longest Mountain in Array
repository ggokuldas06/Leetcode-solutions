class Solution {
public:
    int longestMountain(vector<int>& arr) {
        int ans = 0; 
        int n = arr.size();

        vector<int> inc(n, 1);
        vector<int> dec(n, 1);

        for(int i = 1; i < n; i++){
            if(arr[i] > arr[i-1]){
                inc[i] += inc[i-1];
            }
        }

        for(int i = n-2; i >= 0; i--){
            if(arr[i] > arr[i+1]){
                dec[i] += dec[i+1];
            }
        }

        for(int i = 0; i < n; i++){

            if(inc[i] > 1 && dec[i] > 1){
                ans = max(ans, inc[i] + dec[i] - 1);
            }
        }

        return ans;
    }
};
