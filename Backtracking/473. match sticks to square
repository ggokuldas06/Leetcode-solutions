class Solution {
public:
    bool backtrack(vector<int>& nums,int curr,vector<int>& sides,int leng){
        if(curr==nums.size()){
            return true;
        }
        for(int i=0;i<4;i++){
            if((sides[i]+nums[curr])<=leng){
                sides[i]+=nums[curr];
                if (backtrack(nums,curr+1,sides,leng)){
                    return true;
                }
                sides[i]-=nums[curr];
            }
        }
        return false;
    }
    bool makesquare(vector<int>& matchsticks) {
        vector<int>sides(4,0);
        int sum=0;
        sort(matchsticks.begin(),matchsticks.end(),greater<int>());
        for(int x:matchsticks){
            sum+=x;
        }
        if(sum%4!=0){
            return false;
        }
        int target=sum/4;
        return backtrack(matchsticks,0,sides,target);
    }
};
