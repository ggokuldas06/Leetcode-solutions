class Solution {
public:
    
    int find(int x,vector<int>& parent){
        if(parent[x]!=x){
            parent[x]=find(parent[x],parent);
        }
        return parent[x];
    }
    void unite(int x,int y,vector<int>& parent,vector<int>& rank){
        int rootx=find(x,parent);
        int rooty=find(y,parent);

        if(rooty==rootx)return;
        if(rank[rootx]>rank[rooty]){
            parent[rooty]=rootx;
        }else if(rank[rooty]>rank[rootx]){
            parent[rootx]=rooty;
        }else{
            parent[rootx]=rooty;
            rank[rooty]++;
        }
    }
    int removeStones(vector<vector<int>>& stones) {
        int n=stones.size();
        vector<vector<int>>conn;
        for(int i=0;i<n;i++){
            int x=stones[i][0];
            int y=stones[i][1];
            for(int j=0;j<n;j++){
                if(i!=j){
                    int nx=stones[j][0];
                    int ny=stones[j][1];
                    if(x==nx|| y==ny){
                        conn.push_back({i,j});
                    }
                }
            }
        }
        vector<int>parent(n);
        vector<int>rank(n,0);
        for(int i=0;i<n;i++){
            parent[i]=i;
        }
        for(auto& co:conn){
            unite(co[0],co[1],parent,rank);
        }
        int comp=0;
        for(int i=0;i<n;i++){
            if(parent[i]==i){
                comp++;
            }
        }
        return n-comp;
    }
};
