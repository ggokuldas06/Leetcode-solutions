class Solution {
public:
    vector<vector<int>>graph;
    long long dfs(int node,vector<bool>& seen,int n){
        stack<int>s;
        s.push(node);
        seen[node]=true;
        int ans=0;
        while(!s.empty()){
            int curr=s.top();s.pop();
            ans++;
            for(int v:graph[curr]){
                if(!seen[v]){
                    seen[v]=true;
                    s.push(v);
                }
            }
        }
        return ans;
    }
    long long countPairs(int n, vector<vector<int>>& edges) {
        vector<vector<int>>graph(n);
        for(auto& x:edges){
            int u=x[0];
            int v=x[1];
            graph[u].push_back(v);
            graph[v].push_back(u);
        }
        long long ans=0;
        int rem=n;
        this->graph=graph;
        vector<bool>seen(n,false);
        for(int i=0;i<n;i++){
            if(!seen[i]){
                int size=dfs(i,seen,n);
                ans +=(long long)size*(long long)(rem-size);
                rem-=size;
            }
        }

        return ans;
    }
};
