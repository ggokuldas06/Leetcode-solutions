class Solution {
public:
    bool findSafeWalk(vector<vector<int>>& grid, int health) {
        vector<vector<int>>dirs={{0,1},{1,0},{0,-1},{-1,0}};
        int m=grid.size();
        int n=grid[0].size();
        health -= grid[0][0];
        if(health < 1) return false;
        vector<vector<int>> seen(m, vector<int>(n,-1));
        seen[0][0]=health;
        queue<vector<int>>q;
        q.push({0,0,health});

        while(!q.empty()){
            vector<int> curr=q.front();q.pop();
            int x=curr[0],y=curr[1],h=curr[2];
            if(x==m-1 && y==n-1)return true;
            for(vector<int>& dir:dirs){
                int dx=x+dir[0];
                int dy=y+dir[1];
                if(dx>=0 && dy>=0 && dx<m && dy<n && seen[dx][dy]<h){
                    int nh = h - grid[dx][dy];
                    if(nh >= 1 && nh > seen[dx][dy]){
                        seen[dx][dy] = nh;
                        q.push({dx,dy,nh});
                    }
                }
            }
        }


        return false;
    }
};
